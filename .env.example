# ─── Providers reais (chaves NUNCA hardcode em código) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── Banco-mana (schema gateway) ───────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASS@HOST:PORT/banco-mana

# ─── Admin (cria/revoga chaves virtuais) ───────────────────────────────────
MASTER_KEY=mana-master-gateway-v2-XXXXXXXX

# ─── Railway ───────────────────────────────────────────────────────────────
PORT=8080
